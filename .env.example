# Postgres
POSTGRES_USER=miru
POSTGRES_PASSWORD=miru_secret
POSTGRES_DB=miru_db

# API
NODE_ENV=development
PORT=3333
DATABASE_URL=postgresql://miru:miru_secret@localhost:5432/miru_db
REDIS_URL=redis://localhost:6379

# JWT — troque por strings longas e aleatórias em produção
JWT_SECRET=troque_este_valor_por_algo_seguro_em_producao
JWT_REFRESH_SECRET=outro_valor_seguro_diferente_do_anterior
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# TMDB — obtenha em https://www.themoviedb.org/settings/api
TMDB_API_KEY=sua_chave_aqui

# CORS
CLIENT_URL=http://localhost:5173
